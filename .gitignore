# ============================================================================
# Cloud-Report — root .gitignore
# ============================================================================

# ── Secrets / local config ─────────────────────────────────────────────────
# NEVER commit real .env files (JWT_SECRET, admin password, S3 creds, hashes).
.env
.env.*
!.env.example
*.local

# ── Certificates / private keys ──────────────────────────────────────────────
# TLS certs, private keys, signing certs (PDF sign .p12/.pfx), CSRs, etc.
# Caddy also writes its on-demand CA + leaf certs into its data volume.
*.pem
*.key
*.crt
*.cer
*.der
*.csr
*.p12
*.pfx
*.p7b
*.jks
*.keystore
*.pub
id_rsa
id_ed25519
certs/
certificates/
caddy/data/caddy/      # Caddy-managed CA + issued certificates
# If you intentionally need to track a PUBLIC cert, force-add it:
#   git add -f path/to/public-chain.pem

# ── Node / Nuxt (ui) ─────────────────────────────────────────────────────────
node_modules/
.nuxt/
.output/
.nitro/
.cache/
dist/
.data/
ui/.nuxt/
ui/.output/
ui/node_modules/
# Keep package-lock.json (reproducible installs) — do NOT ignore it.

# ── Go (api) ─────────────────────────────────────────────────────────────────
# Compiled binaries / build output
api/server
api/api
api/cloud-report
api/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
# Test / coverage artifacts
*.test
*.out
coverage.*
# Go workspace file (machine-specific)
go.work
go.work.sum
# Keep go.mod and go.sum — required for builds.

# ── Python (workers) ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.eggs/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Docker / runtime data ──────────────────────────────────────────────────
# Named volumes live in the docker engine, not the repo — but ignore any
# accidental local bind-mount data dirs.
**/data/
# ...except real source code that happens to live in a `data/` dir (the UI
# "Data items" page). Without this the page is silently excluded from git.
!ui/pages/data/
!ui/pages/data/**
caddy/data/
caddy/config/
seaweed-data/
pgdata/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / editor cruft ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~

# ── Misc build / temp ──────────────────────────────────────────────────────
tmp/
.tmp/
*.tmp
*.bak
*.pid

# Workflows n8n exportados (contienen secretos: ES/Cloud-Report API keys)
n8n-workflows/

# Skill / prompts internos del SOC — contienen infra interna (IPs de ELK,
# topologia, nombre de cliente). No publicar en un repo publico.
skill/
