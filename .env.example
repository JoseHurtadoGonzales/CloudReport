# ============================================================================
# Cloud-Report — deployment configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env` (next to docker-compose.yml) and adjust the values
# before `docker compose up -d`. docker-compose auto-loads `.env` and
# substitutes the matching ${VAR} placeholders.
# ============================================================================

# ── Security ────────────────────────────────────────────────────────────────
# Secret used to sign session JWTs. CHANGE THIS in production to a long random
# string (e.g. `openssl rand -hex 32`). Changing it invalidates all sessions.
JWT_SECRET=change-me-in-prod

# Session lifetime in hours. The frontend silently refreshes the token, so a
# high value means "never log me out". 720 = 30 days (default).
SESSION_TTL_HOURS=720

# Allow the public self-registration endpoint (/api/auth/register). For closed
# installs set "false" and create users from Settings → Users instead.
ALLOW_REGISTRATION=true

LOG_LEVEL=info

# ── Initial admin user ────────────────────────────────────────────────────────
# Created automatically the FIRST time the API boots against an empty database.
# Ignored on later boots (never overwrites an existing user). Set these before
# the first boot on a new server.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin123
INITIAL_ADMIN_EMAIL=admin@cloudreport.local

# ── Frontend ──────────────────────────────────────────────────────────────────
# API URL as seen BY THE BROWSER. Behind the Caddy reverse proxy (the default
# setup) LEAVE THIS EMPTY — the browser uses relative URLs (/api, /odata…) on
# the same HTTPS origin. Only set an absolute URL for a direct, no-proxy deploy
# (e.g. http://192.168.1.50:5488). Baked into the bundle: rebuild ui on change.
NUXT_PUBLIC_API_BASE=

# ── Reverse proxy (Caddy) ─────────────────────────────────────────────────────
# Host ports. Defaults are ALTERNATE ports so cloud-report can coexist with
# another reverse proxy already using 80/443 on the same host. On a dedicated
# server set CADDY_HTTPS_PORT=443 (and add an 80→443 redirect in the Caddyfile).
CADDY_HTTPS_PORT=8443            # https://<host>:8443  → frontend + API
N8N_HOST_PORT=5678               # https://<host>:5678  → n8n
SEAWEEDFS_FILER_UI_PORT=19080    # https://<host>:19080 → SeaweedFS filer UI
SEAWEEDFS_MASTER_UI_PORT=19081   # https://<host>:19081 → SeaweedFS master UI
SEAWEEDFS_ADMIN_PORT=19082       # https://<host>:19082 → SeaweedFS Admin Console

# Basic-auth for the SeaweedFS admin UIs. Empty = default admin / cloudreport.
# To set your own: generate a hash with
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-pass'
# then paste it here ESCAPING every $ as $$ (docker-compose interpolates $ in
# .env values, so a raw bcrypt hash gets truncated). Example:
#   SEAWEEDFS_UI_PASSWORD_HASH=$$2a$$14$$abcd...
SEAWEEDFS_UI_USER=admin
SEAWEEDFS_UI_PASSWORD_HASH=

# Credenciales del login propio del Admin Console (form-based, no basic-auth).
# Se usan al iniciar el binario `weed admin`.
SEAWEEDFS_ADMIN_USER=admin
SEAWEEDFS_ADMIN_PASSWORD=cloudreport

# ── n8n (automation, queue mode, OWN postgres + redis) ───────────────────────
# Reached at https://<host>:5678 through Caddy. Set N8N_HOST/WEBHOOK to the
# server's PHYSICAL IP or domain (not localhost) so webhooks resolve.
N8N_HOST=10.71.1.125
N8N_WEBHOOK_URL=https://10.71.1.125:5678/
N8N_TZ=America/La_Paz
N8N_VERSION=latest
N8N_WORKERS=2                  # how many worker replicas pull from the queue
N8N_SECURE_COOKIE=false        # keep false with the self-signed LAN cert

# Encryption key for n8n credentials — MUST be set and NEVER change after first
# boot (changing it makes saved credentials unreadable). Generate with:
#   openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# n8n's dedicated datastores (isolated from the app). Generate strong secrets:
#   openssl rand -hex 16
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=
N8N_REDIS_PASSWORD=

# ── Datastores (defaults work for the bundled containers) ─────────────────────
DATABASE_URL=postgres://cloudreport:cloudreport@postgres:5432/cloudreport?sslmode=disable
REDIS_URL=redis://redis:6379/0
WEED_S3=http://seaweedfs-s3:8333
S3_ACCESS_KEY=cloudreport
S3_SECRET_KEY=cloudreport123
S3_REGION=us-east-1
S3_BUCKET=cloudreport
